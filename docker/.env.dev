# ==========================================
# RAGFlow Development Environment (OIDC Test)
# ==========================================
# 目标：和稳定版隔离的 Dev 环境（独立容器 / 端口 / 网络）

# --- 核心配置：引擎 & 设备 & Profile ---
DOC_ENGINE=elasticsearch
DEVICE=gpu
# 必须启用这两个 profile 才能启动 ES 和 主服务
COMPOSE_PROFILES=elasticsearch,gpu

# --- 基础镜像版本 ---
STACK_VERSION=8.11.3
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0

# --- 端口映射 (Host Ports) ---
# 所有宿主机端口 +10000，避免和稳定版冲突
# Web & API
SVR_WEB_HTTP_PORT=18080     # Dev: http://10.1.9.133:18080
SVR_WEB_HTTPS_PORT=18443
SVR_HTTP_PORT=19380
ADMIN_SVR_HTTP_PORT=19381
SVR_MCP_PORT=19382

# Middleware 端口
# MYSQL_PORT: 宿主机端口映射
# MYSQL_INTERNAL_PORT: 容器内服务连接端口（始终 3306）
MYSQL_PORT=13306
MYSQL_INTERNAL_PORT=3306
ES_PORT=19200
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001
REDIS_PORT=16379
KIBANA_PORT=16601
TEI_PORT=16380
OS_PORT=19201

TEI_IMAGE_CPU=infiniflow/text-embeddings-inference:cpu-1.8
TEI_IMAGE_GPU=infiniflow/text-embeddings-inference:1.8
TEI_MODEL=Qwen/Qwen3-Embedding-0.6B

# Infinity (可选)
INFINITY_THRIFT_PORT=33817
INFINITY_HTTP_PORT=33820
INFINITY_PSQL_PORT=15432

# --- 内部主机名 (Container Hostnames) ---
# 这些在隔离网络内部使用，不需要改
ES_HOST=es01
OS_HOST=opensearch01
INFINITY_HOST=infinity
MYSQL_HOST=mysql
MINIO_HOST=minio
REDIS_HOST=redis
TEI_HOST=tei
SANDBOX_HOST=sandbox-executor-manager

# --- 密码 & 凭证 (Dev 用弱密码即可) ---
ELASTIC_PASSWORD=infini_rag_flow
OPENSEARCH_PASSWORD=infini_rag_flow_OS_01
MYSQL_PASSWORD=infini_rag_flow
MYSQL_DBNAME=rag_flow
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow
REDIS_PASSWORD=infini_rag_flow

# --- 业务配置 ---
REGISTER_ENABLED=1
TZ=Asia/Shanghai
HF_ENDPOINT=https://hf-mirror.com

# --- OIDC SSO 配置 (按需开启) ---
# OIDC_ENABLE=true
# OIDC_PROVIDER=keycloak
# OIDC_CLIENT_ID=your-dev-client-id
# OIDC_CLIENT_SECRET=your-dev-client-secret
# OIDC_REDIRECT_URI=http://10.1.9.133:10080/login/callback  # 注意端口 10080

# --- 资源限制 ---
MEM_LIMIT=4073741824  # 4GB

# --- MinerU & DocLing ---
USE_DOCLING=false
USE_MINERU=true

# --- Dev 环境标识（关键） ---
# 驱动 docker-compose-base.yml 中的容器名和网络选择
CONTAINER_PREFIX=ragflow-dev
NETWORK_NAME=ragflow-dev-net
FEISHU_REDIRECT_URI=https://10.1.9.133:10443/v1/user/oauth/callback/feishu
# MinerU 配置 - 使用 API 服务器
MINERU_BACKEND=vlm-vllm-async-engine
MINERU_APISERVER=http://host.docker.internal:9987
